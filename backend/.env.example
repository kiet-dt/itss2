# Gemini API Key (Google AI Studio)
# Lấy tại: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Model ưu tiên quota cao: gemini-2.5-flash-lite (mặc định)
# GEMINI_MODEL=gemini-2.5-flash-lite

# SQLite — local dev để trống (mặc định backend/data). Railway: /app/data (volume)
# DATA_DIR=/app/data
